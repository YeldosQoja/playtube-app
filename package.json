{
  "name": "video-streaming-app-server",
  "version": "1.0.0",
  "description": "Server app for video streaming app",
  "main": "src/index.js",
  "type": "module",
  "imports": {
    "#app/*.js": "./dist/app/*.js",
    "#config/aws.js": "./dist/config/aws.js",
    "#db": "./dist/db/index.js",
    "#db/queries.js": "./dist/db/queries.js",
    "#db/schema/*.js": "./dist/db/schema/*.js",
    "#middlewares/*.js": "./dist/middlewares/*.js",
    "#lib/*.js": ".dist/lib/*.js",
    "#utils/*.js": "./dist/utils/*.js",
    "#services/*.js": "./dist/services/*.js",
    "#validators/*.js": "./dist/validators/*.js"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon dist/index.js",
    "makemigrations": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "start:worker": "node dist/worker.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YeldosQoja/video-streaming-app-server.git"
  },
  "keywords": [
    "Video",
    "streaming",
    "youtube",
    "twitch",
    "live"
  ],
  "author": "YeldosQoja",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/YeldosQoja/video-streaming-app-server/issues"
  },
  "homepage": "https://github.com/YeldosQoja/video-streaming-app-server#readme",
  "dependencies": {
    "@aws-sdk/client-mediaconvert": "^3.834.0",
    "@aws-sdk/client-s3": "^3.812.0",
    "@aws-sdk/client-secrets-manager": "^3.990.0",
    "@aws-sdk/client-sqs": "^3.956.0",
    "@aws-sdk/cloudfront-signer": "^3.858.0",
    "@aws-sdk/lib-storage": "^3.812.0",
    "@aws-sdk/s3-request-presigner": "^3.815.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.41.0",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-session": "^1.18.1",
    "multer": "^2.0.0",
    "nanoid": "^5.1.5",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.15",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.4",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3"
  }
}
